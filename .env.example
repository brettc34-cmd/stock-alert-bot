# Required
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace-me
DISCORD_BOT_TOKEN=replace-me
STOCK_ALERT_DASHBOARD_KEY=replace-with-strong-random-value

# Optional local durability / observability
REDIS_URL=redis://localhost:6379/0
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_ENABLE_PROMETHEUS=0

# Market session defaults (US markets)
MARKET_TIMEZONE=US/Eastern
MARKET_OPEN=09:30
MARKET_CLOSE=16:00

# Scheduler controls
DISABLE_INTERNAL_SCHEDULER=0
SCHEDULER_RUN_NEAR_CLOSE=1
SCHEDULER_CLOSE_OFFSET_MINUTES=10

# Nightly report job controls
REPORT_TIME=21:00
REPORT_DAYS=1

# Daily market update (Discord only)
MARKET_UPDATE_ENABLED=1
MARKET_UPDATE_TIME=07:00
MARKET_UPDATE_TIMEZONE=America/Chicago

# Daily S&P 500 overview (Discord webhook delivery)
SP500_OVERVIEW_ENABLED=1
SP500_OVERVIEW_TIME=07:00
SP500_OVERVIEW_TIMEZONE=America/Chicago
SP500_OVERVIEW_MAX_WORDS=250
SP500_OVERVIEW_SUBJECT_PREFIX=
SP500_OVERVIEW_LOG_PATH=storage/sp500_overview_history.jsonl

# Optional browser convenience for /reports access
ENABLE_QUERY_API_KEY=0

# Interactive bot metrics port
INTERACTIVE_BOT_METRICS_PORT=9101
